{
  "name": "fides-use-case-catalog",
  "version": "1.0.0",
  "description": "FIDES Community Use Case Catalog - Real-world verifiable credential use cases, submitted via WordPress and published per organization, aggregated for the FIDES ecosystem.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "crawl": "tsx src/crawler/index.ts",
    "sync": "USE_CASE_SYNC=1 tsx src/crawler/index.ts",
    "build": "tsc",
    "dev": "tsx watch src/crawler/index.ts",
    "validate": "ajv validate --spec=draft2020 -c ajv-formats -s schemas/use-case-catalog.schema.json -d 'community-catalogs/**/use-case-catalog.json'"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/FIDEScommunity/fides-use-case-catalog.git"
  },
  "keywords": [
    "verifiable-credentials",
    "use-cases",
    "ssi",
    "decentralized-identity",
    "fides"
  ],
  "author": "FIDES Community",
  "license": "Apache-2.0",
  "dependencies": {
    "ajv": "^8.12.0",
    "ajv-formats": "^2.1.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@vercel/node": "^3.0.0",
    "ajv-cli": "^5.0.0",
    "tsx": "^4.6.2",
    "typescript": "^5.3.2"
  }
}
