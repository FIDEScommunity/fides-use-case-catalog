    {
      "id": "ca-dmv-mdl-website-login",
      "sector": "public_sector",
      "title": "Driver's license login for government services",
      "summary": "Residents log in to government online services using the mobile driver's license (mDL) already in their wallet, instead of creating yet another username and password. The DMV acts as the relying party and verifies the mDL through an ISO/IEC 18013-5 mdoc presentation, so the user only shares the attributes needed to authenticate. This is one of the first production deployments of wallet-based, passwordless login to a public-sector service.",
      "organizationName": "California DMV",
      "productionDeployment": "yes",
      "status": "published",
      "updatedAt": "2026-06-09T12:00:00+00:00",
      "publishedAt": "2026-06-09T12:00:00+00:00",
      "country": "US",
      "tags": [
        "mdl",
        "passwordless-login",
        "public-services",
        "data-minimisation",
        "iso-18013-5"
      ],
      "interactionModes": [
        "remote"
      ],
      "vcFormats": [
        "mdoc"
      ],
      "presentationProtocols": [
        "ISO 18013-5"
      ],
      "moreInfoUrl": "https://www.dmv.ca.gov/portal/dmv-wallet/",
      "userJourney": "1) The resident already holds a mobile driver's license (mDL) issued by the DMV in a supported wallet.\n2) They open a government online service and choose to log in with their driver's license.\n3) The service (relying party) requests an mDL presentation over an ISO/IEC 18013-5 mdoc flow.\n4) The wallet shows exactly which attributes are requested; the resident approves.\n5) The relying party verifies the presentation and signs the resident in, without a password and without collecting more data than needed.",
