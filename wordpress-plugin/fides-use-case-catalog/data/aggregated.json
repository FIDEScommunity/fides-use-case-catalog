    {
      "id": "nijmegen-attribute-based-municipal-login",
      "sector": "public_sector",
      "title": "Municipal login with attribute-based credentials",
      "summary": "Citizens log in to their municipal account and securely share only the personal attributes a service actually needs, using an attribute-based wallet. The municipality acts as the relying party and verifies the presented attributes over the IRMA protocol. This is one of the first production implementations of attribute-based authentication in Dutch municipal services, showing that privacy-friendly login at scale is possible today.",
      "organizationName": "Gemeente Nijmegen",
      "productionDeployment": "yes",
      "status": "published",
      "updatedAt": "2026-06-09T12:00:00+00:00",
      "publishedAt": "2026-06-09T12:00:00+00:00",
      "country": "NL",
      "tags": [
        "municipal-login",
        "attribute-based",
        "data-minimisation",
        "irma",
        "public-services"
      ],
      "interactionModes": [
        "remote"
      ],
      "vcFormats": [
        "idemix"
      ],
      "presentationProtocols": [
        "IRMA Protocol"
      ],
      "moreInfoUrl": "https://mijn.nijmegen.nl/login",
      "userJourney": "1) The citizen has loaded personal attributes (e.g. name, email, mobile number) into an attribute-based wallet.\n2) They open their municipal account and choose to log in with the wallet.\n3) The municipality (relying party) requests only the attributes required for the service over the IRMA protocol.\n4) The citizen reviews the request in the wallet and confirms disclosure.\n5) The municipality verifies the attributes and grants access, without storing more personal data than necessary.",
