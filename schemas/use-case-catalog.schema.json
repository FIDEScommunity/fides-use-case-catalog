{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fides.community/schemas/use-case-catalog/v1",
  "title": "FIDES Use Case Catalog (per-organization source file)",
  "description": "One file per submitting organization. Generated from the WordPress submission DB via the /export endpoint and aggregated by the crawler into data/aggregated.json.",
  "type": "object",
  "required": ["orgId", "useCases"],
  "properties": {
    "$schema": { "type": "string" },
    "orgId": { "type": "string", "minLength": 1 },
    "orgName": { "type": "string" },
    "useCases": {
      "type": "array",
      "items": { "$ref": "#/$defs/useCase" }
    }
  },
  "additionalProperties": true,
  "$defs": {
    "useCase": {
      "type": "object",
      "required": ["id", "title", "summary"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "summary": { "type": "string" },
        "sector": { "type": "string" },
        "organizationName": { "type": "string" },
        "productionDeployment": { "type": "string", "enum": ["yes", "no", ""] },
        "status": { "type": "string" },
        "country": { "type": "string" },
        "updatedAt": { "type": "string" },
        "publishedAt": { "type": ["string", "null"] },
        "moreInfoUrl": { "type": "string" },
        "userJourney": { "type": "string" },
        "imageUrl": { "type": "string" },
        "imageUrls": { "type": "array", "items": { "type": "string" } },
        "tags": { "type": "array", "items": { "type": "string" } },
        "interactionModes": { "type": "array", "items": { "type": "string" } },
        "vcFormats": { "type": "array", "items": { "type": "string" } },
        "issuanceProtocols": { "type": "array", "items": { "type": "string" } },
        "presentationProtocols": { "type": "array", "items": { "type": "string" } },
        "interopProfiles": { "type": "array", "items": { "type": "string" } },
        "links": { "type": "object" },
        "video": { "type": ["object", "null"] },
        "videos": { "type": "array" }
      },
      "additionalProperties": true
    }
  }
}
