{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fides.community/schemas/use-case-catalog/v1.1",
  "title": "FIDES Use Case Catalog Aggregated Schema",
  "type": "object",
  "required": ["schemaVersion", "catalogType", "lastUpdated", "useCases"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1.1.0"
    },
    "catalogType": {
      "type": "string",
      "const": "use-case-catalog"
    },
    "lastUpdated": {
      "type": "string",
      "format": "date-time"
    },
    "useCases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "sector",
          "title",
          "summary",
          "organizationName",
          "status",
          "updatedAt"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "sector": {
            "type": "string",
            "minLength": 1
          },
          "interactionModes": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["remote", "proximity"]
            }
          },
          "vcFormats": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "issuanceProtocols": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["oid4vci", "other"]
            }
          },
          "presentationProtocols": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "interopProfiles": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "title": {
            "type": "string",
            "minLength": 5,
            "maxLength": 120
          },
          "summary": {
            "type": "string",
            "minLength": 30,
            "maxLength": 1200
          },
          "userJourney": {
            "type": "string",
            "minLength": 1,
            "maxLength": 8000
          },
          "organizationName": {
            "type": "string",
            "minLength": 2,
            "maxLength": 120
          },
          "country": {
            "type": "string",
            "pattern": "^[A-Z]{2}$|^EU$",
            "description": "ISO 3166-1 alpha-2 country code or EU for pan-European use cases"
          },
          "stage": {
            "type": "string",
            "enum": ["demo", "production"]
          },
          "imageUrl": {
            "type": "string",
            "format": "uri"
          },
          "moreInfoUrl": {
            "type": "string",
            "format": "uri"
          },
          "video": {
            "type": "object",
            "required": ["url", "provider"],
            "properties": {
              "url": {
                "type": "string",
                "format": "uri"
              },
              "provider": {
                "type": "string",
                "enum": ["youtube", "vimeo"]
              }
            },
            "additionalProperties": false
          },
          "links": {
            "type": "object",
            "properties": {
              "personalWallets": {
                "$ref": "#/$defs/linksList"
              },
              "businessWallets": {
                "$ref": "#/$defs/linksList"
              },
              "wallets": {
                "$ref": "#/$defs/linksList"
              },
              "issuers": {
                "$ref": "#/$defs/linksList"
              },
              "credentials": {
                "$ref": "#/$defs/linksList"
              },
              "organizations": {
                "$ref": "#/$defs/linksList"
              },
              "rps": {
                "$ref": "#/$defs/linksList"
              }
            },
            "additionalProperties": false
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 64
            }
          },
          "status": {
            "type": "string",
            "enum": ["received", "approved", "published"]
          },
          "publishedAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "$defs": {
    "linkItem": {
      "type": "object",
      "properties": {
        "refId": {
          "type": ["string", "null"]
        },
        "labelRaw": {
          "type": ["string", "null"]
        },
        "url": {
          "type": ["string", "null"],
          "format": "uri"
        },
        "source": {
          "type": "string",
          "enum": ["catalog", "manual"]
        }
      },
      "required": ["refId", "labelRaw", "url", "source"],
      "additionalProperties": false
    },
    "linksList": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/linkItem"
      }
    }
  },
  "additionalProperties": false
}
