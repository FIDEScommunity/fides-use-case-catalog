      "id": "ca-dmv-mdl-website-login",
      "sector": "public_sector",
      "title": "Driver's license login for government services",
      "summary": "Residents log in to government online services using the mobile driver's license (mDL) already in their wallet, instead of creating yet another username and password. The DMV acts as the relying party and verifies the mDL through an ISO/IEC 18013-5 mdoc presentation, so the user only shares the attributes needed to authenticate. This is one of the first production deployments of wallet-based, passwordless login to a public-sector service.",
      "organizationName": "California DMV",
      "productionDeployment": "yes",
      "status": "published",
